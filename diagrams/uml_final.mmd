%% PawPal+ — Phase 6 FINAL UML
%% Matches the final implementation in pawpal_system.py.
classDiagram
    class Owner {
        +str name
        +list~Pet~ pets
        +add_pet(pet) None
        +get_pet(name) Pet
        +all_tasks() list~tuple~
    }

    class Pet {
        +str name
        +str species
        +list~Task~ tasks
        +add_task(task) None
        +list_tasks() list~Task~
        +pending_tasks() list~Task~
        +task_count() int
    }

    class Task {
        +str description
        +str time
        +int duration_minutes
        +str priority
        +str frequency
        +bool completed
        +date due_date
        +mark_complete() None
        +priority_rank() int
        +next_occurrence() Task
    }

    class Scheduler {
        +Owner owner
        +all_tasks() list~Task~
        +sort_by_time() list~Task~
        +sort_by_priority() list~Task~
        +filter_by_pet(name) list~Task~
        +filter_by_status(completed) list~Task~
        +filter_by_priority(priority) list~Task~
        +detect_conflicts() list~str~
        +complete_task(pet, task) Task
        +todays_schedule() str
    }

    Owner "1" o-- "many" Pet : has
    Pet "1" o-- "many" Task : has
    Scheduler --> Owner : organizes tasks across pets
    Scheduler ..> Task : sorts / filters / completes

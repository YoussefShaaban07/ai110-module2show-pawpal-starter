%% PawPal+ — Phase 1 DRAFT UML
%% First-pass design before implementation. Kept for comparison with uml_final.mmd.
classDiagram
    class Owner {
        +str name
        +list~Pet~ pets
        +add_pet(pet) None
        +get_pet(name) Pet
    }

    class Pet {
        +str name
        +str species
        +list~Task~ tasks
        +add_task(task) None
        +list_tasks() list~Task~
    }

    class Task {
        +str description
        +str time
        +int duration_minutes
        +str priority
        +str frequency
        +bool completed
        +mark_complete() None
    }

    class Scheduler {
        +Owner owner
        +sort_by_time() list~Task~
        +detect_conflicts() list~str~
    }

    Owner "1" --> "many" Pet : has
    Pet "1" --> "many" Task : has
    Scheduler --> Owner : reads
